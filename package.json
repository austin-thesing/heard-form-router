{
  "name": "@austinthesing/form-router",
  "version": "1.0.0",
  "description": "Shared form routing logic for Heard's qualification forms",
  "private": true,
  "main": "src/routing-logic.js",
  "type": "module",
  "exports": {
    ".": "./src/routing-logic.js",
    "./form-router": "./src/form-router.js",
    "./ms-form-router": "./src/ms-form-router.js",
    "./dist/routing-logic.min": "./dist/routing-logic.min.js"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "scripts": {
    "build": "esbuild src/routing-logic.js --bundle --minify --outfile=dist/routing-logic.min.js --format=esm",
    "prepublishOnly": "npm run build"
  },
  "author": "Austin Thesing/Design X Develop",
  "license": "UNLICENSED",
